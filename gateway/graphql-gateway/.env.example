# Server
PORT=4000
WEBSOCKET_PORT=4001

# Environment
NODE_ENV=development

# GraphQL
GRAPHQL_INTROSPECTION=true
GRAPHQL_PLAYGROUND=true

# Subgraph URLs
ORDER_SERVICE_URL=http://localhost:3001/graphql
USER_SERVICE_URL=http://localhost:3005/graphql

# Redis for subscriptions
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info